---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Project from '../components/Project.astro';
import GithubLink from '../components/GithubLink.astro';
---

<Layout
  title="Research · Sylvain Estebe"
  description="Research projects on cultural evolution, collective decision-making, and individual cognition. Plus software contributions and past explorations."
>
  <ThemeToggle />

  <header class="blog-header">
    <h1>Research</h1>
    <p class="pitch">Current projects, past explorations, and open-source contributions — grouped by the scale of the question.</p>
  </header>

  <h2>Population · Cultural evolution</h2>
  <Project
    title="Romantic love in French fiction, 1500–1999"
    question="Does the rise of romantic love in fiction track changes in resource abundance?"
    status="Manuscript in preparation"
  >
    A behavioral-ecology approach on a corpus of French novels: does the literary record of romantic love move with material conditions across five centuries? Built using LLM annotation, bag-of-words, and time-series analysis. With Nicolas Baumard (Institut Jean Nicod, ENS/PSL).
  </Project>

  <h2>Group · Collective decision-making</h2>
  <Project
    title="Quadratic voting and polarization"
    question="When the environment turns volatile, can a voting rule like quadratic voting let agents express how strongly they believe — not just which side they're on?"
    status="Manuscript in preparation"
  >
    An <strong>agent-based model</strong> of Bayesian agents comparing plurality vs. quadratic voting under environmental volatility (economic shocks, security crises), and whether mechanism design can carry preference and belief into the outcome. With Nicolas Legrand (CHC, Aarhus).
  </Project>

  <h2>Individual · Computational cognitive science</h2>
  <Project
    title="A cognitive model of customer churn"
    question="What's the decision process behind leaving a service — and can modeling it beat black-box prediction?"
    status="Completed · MSc thesis (grade A)"
  >
    A <strong>hierarchical Bayesian model</strong> (PyMC) of how beliefs about a service evolve and tip into leaving — used to inform data-collection strategy. Industry collaboration with Norlys. Supervisor: Nicolas Legrand.
  </Project>

  <h2>Past explorations</h2>
  <Project
    title="Insecurity and cooperation across 13 countries"
    scale="Group"
    question="Does perceived insecurity make people cooperate less?"
  >
    <strong>Decision-making modeling</strong> on public-goods-game data across 13 countries. Perceived insecurity predicts lower contributions and faster cooperation decline — people from high-insecurity nations show lower initial optimism and greater sensitivity to others' choices. <GithubLink href="https://github.com/SylvainEstebe/decision_making_modeling" />
  </Project>

  <Project
    title="Predicting the intention–action gap in childcare"
    scale="Population"
    question="Can we predict who closes the gap between intending to use childcare and actually doing it?"
  >
    End-to-end <strong>ML pipeline</strong> (Python) on inequality and childcare data: preprocessing, model fitting, forecasting, evaluation, visualization. <GithubLink href="https://github.com/SylvainEstebe/predict_intention_action_gap" />
  </Project>

  <Project
    title="Cognitive distortions in embedding space"
    scale="Individual"
    question="Do cognitive-distortion categories have a natural structure in embedding space?"
  >
    <strong>NLP</strong> pipeline: sentence-transformer embeddings → UMAP → HDBSCAN clustering (Bayesian-optimized) on 921 labeled thought examples. <GithubLink href="https://github.com/SylvainEstebe/cognitive_distortion_embeding" label="Code & dashboard" />
  </Project>

  <Project
    title="Cognitive effort in musical performance"
    scale="Individual"
    question="How much cognitive and physical effort does piano performance really take?"
  >
    <strong>Experimental</strong> work across two internships at the University of Oslo with Laura Bishop and Bruno Laeng — motion capture, mobile eye-tracking, and EMG, with wavelet-based multimodal analysis.
  </Project>

  <h2>Software</h2>
  <Project title="european-city-inference">
    Creator and maintainer of an open-source <strong>agent-based modeling</strong> library (Python) for studying collective decision-making (Center for Humanities Computing, Aarhus). Contributions welcome — <a href="https://github.com/centre-for-humanities-computing/european-city-inference">repository</a> opening soon.
  </Project>

  <Project title="PyHGF">
    Contributor to the open-source <a href="https://computationalpsychiatry.github.io/pyhgf/">Hierarchical Gaussian Filter library</a> — <strong>JAX</strong>-based predictive coding for computational psychiatry.
  </Project>

  <SiteFooter />
</Layout>
