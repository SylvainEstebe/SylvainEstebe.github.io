---
import path from 'node:path';
import exifr from 'exifr';
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PhotoTile from '../../components/PhotoTile.astro';
import { photoMeta } from '../../data/photos.meta';
import { exhibitions } from '../../data/exhibitions';

// Auto-discover every photo in src/content/photos/. New images appear in the
// gallery the moment you drop them in — no edits to this file required.
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../content/photos/*.{jpg,jpeg,JPG,JPEG,png,PNG}',
  { eager: true }
);

const photosDir = path.resolve(process.cwd(), 'src/content/photos');

async function readExifDate(absPath: string): Promise<string | undefined> {
  try {
    const exif = await exifr.parse(absPath, { pick: ['DateTimeOriginal', 'CreateDate'] });
    const d: Date | string | undefined = exif?.DateTimeOriginal ?? exif?.CreateDate;
    if (d instanceof Date && !isNaN(d.getTime())) return d.toISOString().slice(0, 10);
    if (typeof d === 'string' && d.length >= 10) return d.slice(0, 10);
  } catch (err) {
    console.warn(`[photos] EXIF read failed for ${absPath}:`, (err as Error).message);
  }
  return undefined;
}

const discovered = await Promise.all(
  Object.entries(photoModules).map(async ([globPath, mod]) => {
    const filename = globPath.split('/').pop()!;
    const absPath = path.join(photosDir, filename);
    const meta = photoMeta[filename] ?? {};
    const exifDate = await readExifDate(absPath);
    return {
      src: mod.default,
      filename,
      alt: meta.alt ?? '',
      caption: meta.caption,
      location: meta.location,
      exhibition: meta.exhibition,
      // priority: explicit override → EXIF → empty
      date: meta.date ?? exifDate ?? '',
    };
  })
);

// Sort newest first; entries without a date sink to the bottom.
const sorted = discovered.sort((a, b) => {
  if (!a.date && !b.date) return 0;
  if (!a.date) return 1;
  if (!b.date) return -1;
  return b.date.localeCompare(a.date);
});

// Attach a stable global index — this is what the lightbox navigates by, so it
// must stay consistent regardless of how photos are grouped on the page.
const indexed = sorted.map((p, i) => ({ ...p, idx: i }));

// Group by exhibition. Loose photos (no exhibition) lead the page; each
// exhibition that has photos becomes a titled gallery section below.
const loose = indexed.filter((p) => !p.exhibition);
const exhibitionGroups = exhibitions
  .map((ex) => ({ ex, photos: indexed.filter((p) => p.exhibition === ex.id) }))
  .filter((g) => g.photos.length > 0);

// Pre-render a large optimized variant per photo for the lightbox.
const fullSize = await Promise.all(
  sorted.map((p) => getImage({ src: p.src, width: 1800, format: 'webp', quality: 88 }))
);

const lightboxData = sorted.map((p, i) => ({
  url: fullSize[i].src,
  width: p.src.width,
  height: p.src.height,
  alt: p.alt,
  caption: p.caption ?? '',
  location: p.location ?? '',
  date: p.date,
}));
---

<Layout
  title="Photos · Sylvain Estebe"
  description="A small collection of photographs."
  wide
>
  <ThemeToggle />

  <header class="blog-header">
    <h1>Photos</h1>
    <p class="pitch">A small, slowly growing collection.</p>
  </header>

  {sorted.length === 0 ? (
    <div class="photos-empty">
      <p style="margin: 0 0 0.6rem 0;">No photos yet. To add some:</p>
      <ol style="margin: 0; padding-left: 1.2rem;">
        <li>Drop JPGs into <code>src/content/photos/</code> — they appear automatically</li>
        <li>Date is read from EXIF; if you want a caption or location, add it to <code>src/data/photos.meta.ts</code></li>
      </ol>
    </div>
  ) : (
    <>
      <div id="galleries">
        {loose.length > 0 && (
          <div class="justified-gallery">
            {loose.map((photo) => <PhotoTile photo={photo} index={photo.idx} />)}
          </div>
        )}

        {exhibitionGroups.map(({ ex, photos }) => (
          <section class="photo-exhibition">
            <div class="photo-exhibition__head">
              <h2>{ex.title}</h2>
              <p class="photo-exhibition__meta">
                {[[ex.venue, ex.city].filter(Boolean).join(', '), ex.date].filter(Boolean).join(' · ')}
                {ex.link && <> <a href={ex.link} target="_blank" rel="noopener" aria-label={`${ex.title} — external link`}>↗</a></>}
              </p>
              {ex.note && <p class="photo-exhibition__note">{ex.note}</p>}
            </div>
            <div class="justified-gallery">
              {photos.map((photo) => <PhotoTile photo={photo} index={photo.idx} />)}
            </div>
          </section>
        ))}
      </div>

      <dialog class="lightbox" id="lightbox" aria-label="Photo viewer">
        <button type="button" class="lightbox__nav lightbox__nav--prev" data-action="prev" aria-label="Previous photo">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button type="button" class="lightbox__nav lightbox__nav--next" data-action="next" aria-label="Next photo">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <button type="button" class="lightbox__close" data-action="close" aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <figure class="lightbox__stage">
          <img class="lightbox__img" alt="" />
          <figcaption class="lightbox__caption">
            <span class="lightbox__caption-text"></span>
            <span class="lightbox__caption-meta"></span>
          </figcaption>
        </figure>
      </dialog>

      <script is:inline define:vars={{ photos: lightboxData }}>
        (function () {
          const dialog = document.getElementById('lightbox');
          const gallery = document.getElementById('galleries');
          if (!dialog || !gallery) return;
          const imgEl = dialog.querySelector('.lightbox__img');
          const capText = dialog.querySelector('.lightbox__caption-text');
          const capMeta = dialog.querySelector('.lightbox__caption-meta');
          let current = 0;

          // ── Zoom + pan state ─────────────────────────────────────────
          const MIN_SCALE = 1;
          const MAX_SCALE = 4;
          const ZOOM_IN_FACTOR = 2;     // single-click zoom factor
          let scale = 1;
          let tx = 0, ty = 0;
          let baseW = 0, baseH = 0;     // rendered size at scale=1
          let dragging = false;
          let dragStartX = 0, dragStartY = 0;
          let dragOrigTx = 0, dragOrigTy = 0;
          let didDrag = false;

          function applyTransform() {
            imgEl.style.transform = 'translate(' + tx + 'px, ' + ty + 'px) scale(' + scale + ')';
            imgEl.classList.toggle('is-zoomed', scale > 1.001);
            imgEl.classList.toggle('is-dragging', dragging);
          }

          function clampPan() {
            const vw = window.innerWidth, vh = window.innerHeight;
            const maxTx = Math.max(0, (baseW * scale - vw) / 2);
            const maxTy = Math.max(0, (baseH * scale - vh) / 2);
            tx = Math.max(-maxTx, Math.min(maxTx, tx));
            ty = Math.max(-maxTy, Math.min(maxTy, ty));
          }

          function resetZoom() {
            scale = 1; tx = 0; ty = 0;
            applyTransform();
          }

          /** Zoom by `factor` keeping the point (cx, cy) fixed under the cursor. */
          function zoomAt(cx, cy, factor) {
            const vw = window.innerWidth, vh = window.innerHeight;
            const dx = cx - vw / 2;
            const dy = cy - vh / 2;
            const newScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, scale * factor));
            if (newScale === scale) return;
            const F = newScale / scale;
            tx = dx - (dx - tx) * F;
            ty = dy - (dy - ty) * F;
            scale = newScale;
            if (scale <= 1.001) { tx = 0; ty = 0; }
            clampPan();
            applyTransform();
          }

          // ── Show / open / close ──────────────────────────────────────
          function show(i) {
            resetZoom();
            current = (i + photos.length) % photos.length;
            const p = photos[current];
            imgEl.src = p.url;
            imgEl.alt = p.alt;
            imgEl.width = p.width;
            imgEl.height = p.height;
            capText.textContent = p.caption || '';
            const meta = [];
            if (p.date) {
              meta.push(new Date(p.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' }));
            }
            if (p.location) meta.push(p.location);
            capMeta.textContent = meta.join(' · ');
          }

          function open(i) {
            show(i);
            if (typeof dialog.showModal === 'function') dialog.showModal();
            else dialog.setAttribute('open', '');
            document.body.style.overflow = 'hidden';
          }

          function close() {
            if (typeof dialog.close === 'function') dialog.close();
            else dialog.removeAttribute('open');
            document.body.style.overflow = '';
            imgEl.removeAttribute('src');
            resetZoom();
          }

          // Capture intrinsic rendered size when each image loads.
          imgEl.addEventListener('load', () => {
            // Image is at scale=1 here (we reset before src change).
            const r = imgEl.getBoundingClientRect();
            baseW = r.width;
            baseH = r.height;
          });

          // ── Wiring ───────────────────────────────────────────────────
          gallery.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-index]');
            if (!btn) return;
            open(Number(btn.dataset.index));
          });

          // Click on backdrop / caption area / nav buttons.
          dialog.addEventListener('click', (e) => {
            // Image has its own click handler — never close from image clicks.
            if (e.target === imgEl) return;
            const action = e.target.closest('[data-action]')?.dataset.action;
            if (action === 'prev') return show(current - 1);
            if (action === 'next') return show(current + 1);
            if (action === 'close') return close();
            // Click outside the image (cream backdrop, caption area) → close.
            close();
          });

          // Click on the image → toggle zoom at click point (unless we just dragged).
          imgEl.addEventListener('click', (e) => {
            e.stopPropagation();
            if (didDrag) { didDrag = false; return; }
            if (scale > 1.001) {
              resetZoom();
            } else {
              zoomAt(e.clientX, e.clientY, ZOOM_IN_FACTOR);
            }
          });

          // Wheel → zoom at cursor.
          imgEl.addEventListener('wheel', (e) => {
            e.preventDefault();
            const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
            zoomAt(e.clientX, e.clientY, factor);
          }, { passive: false });

          // Mouse drag → pan (when zoomed).
          imgEl.addEventListener('mousedown', (e) => {
            if (scale <= 1.001) return;
            e.preventDefault();
            dragging = true;
            didDrag = false;
            dragStartX = e.clientX;
            dragStartY = e.clientY;
            dragOrigTx = tx;
            dragOrigTy = ty;
            applyTransform();
          });

          window.addEventListener('mousemove', (e) => {
            if (!dragging) return;
            const dx = e.clientX - dragStartX;
            const dy = e.clientY - dragStartY;
            if (Math.abs(dx) > 4 || Math.abs(dy) > 4) didDrag = true;
            tx = dragOrigTx + dx;
            ty = dragOrigTy + dy;
            clampPan();
            applyTransform();
          });

          window.addEventListener('mouseup', () => {
            if (!dragging) return;
            dragging = false;
            applyTransform();
          });

          // Touch drag → pan (single-finger when zoomed).
          imgEl.addEventListener('touchstart', (e) => {
            if (scale <= 1.001 || e.touches.length !== 1) return;
            dragging = true;
            didDrag = false;
            dragStartX = e.touches[0].clientX;
            dragStartY = e.touches[0].clientY;
            dragOrigTx = tx;
            dragOrigTy = ty;
          }, { passive: true });

          imgEl.addEventListener('touchmove', (e) => {
            if (!dragging || e.touches.length !== 1) return;
            e.preventDefault();
            const dx = e.touches[0].clientX - dragStartX;
            const dy = e.touches[0].clientY - dragStartY;
            if (Math.abs(dx) > 4 || Math.abs(dy) > 4) didDrag = true;
            tx = dragOrigTx + dx;
            ty = dragOrigTy + dy;
            clampPan();
            applyTransform();
          }, { passive: false });

          imgEl.addEventListener('touchend', () => {
            if (dragging) dragging = false;
            applyTransform();
          });

          // Keyboard navigation (zoom resets in show()).
          document.addEventListener('keydown', (e) => {
            if (!dialog.open) return;
            if (e.key === 'ArrowLeft') show(current - 1);
            else if (e.key === 'ArrowRight') show(current + 1);
            else if (e.key === '0' || e.key === 'Escape' && scale > 1.001) {
              // 0 resets zoom; Escape when zoomed resets first instead of closing
              if (e.key === '0') resetZoom();
            }
          });

          // Reset on close (dialog can also close via Esc natively).
          dialog.addEventListener('close', () => {
            document.body.style.overflow = '';
            imgEl.removeAttribute('src');
            resetZoom();
          });
        })();
      </script>
    </>
  )}

  <SiteFooter />
</Layout>
