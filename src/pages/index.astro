---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SocialLinks from '../components/SocialLinks.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Project from '../components/Project.astro';
import GithubLink from '../components/GithubLink.astro';

const recent = (
  await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<Layout
  title="Sylvain Estebe · Computational cognitive science & cultural evolution"
  description="Computational cognitive science, cultural evolution, and computational social science. Machine learning, Bayesian modeling, LLM pipelines, agent-based simulation."
  preloadImages={["/profile.jpg"]}
>
  <ThemeToggle />

  <div class="site-header">
    <img src="/profile.jpg" alt="Sylvain Estebe" />
    <div class="header-text">
      <h1>Sylvain Estebe</h1>
      <p class="affiliation">Research Assistant · Aarhus University (Center for Humanities Computing)</p>
    </div>
  </div>

  <div class="pitch">
    <p>I build computational models of how people and groups behave — Bayesian cognitive models, decision-making models, agent-based simulations — and use applied data science — segmentation models, forecasting, LLM annotation, time series — to study behavior at scale. My work spans individual cognition, collective decision-making, and cultural evolution, with a common thread: how environmental conditions (resources, volatility) shape behavior.</p>
    <p class="pitch__more"><a href="/about">More about me →</a></p>
  </div>

  <SocialLinks />

  <h2>Research</h2>

  <h3>Population · Cultural evolution</h3>
  <Project
    title="Romantic love in French fiction, 1500–1999"
    question="Does the rise of romantic love in fiction track changes in resource abundance?"
    status="Manuscript in preparation"
  >
    A behavioral-ecology test on a corpus of French novels, built with <strong>NLP</strong> — LLM annotation, bag-of-words, and time-series analysis. With Nicolas Baumard (Institut Jean Nicod, ENS/PSL).
  </Project>

  <h3>Group · Collective decision-making</h3>
  <Project
    title="Quadratic voting and polarization"
    question="When the environment turns volatile, can a voting rule like quadratic voting let agents express how strongly they believe — not just which side they're on?"
    status="Manuscript in preparation"
  >
    An <strong>agent-based model</strong> of Bayesian agents comparing plurality vs. quadratic voting under economic shocks and security crises. With Nicolas Legrand (CHC, Aarhus).
  </Project>

  <h3>Individual · Computational cognitive science</h3>
  <Project
    title="A cognitive model of customer churn"
    question="What's the decision process behind leaving a service — and can modeling it beat black-box prediction?"
    status="Completed · MSc thesis (grade A)"
  >
    A <strong>hierarchical Bayesian model</strong> (PyMC) of how beliefs about a service evolve and tip into leaving. Industry collaboration with Norlys. Supervisor: Nicolas Legrand.
  </Project>

  <p class="more-link"><a href="/research">All work, past explorations & software →</a></p>

  <h2>Talks & updates</h2>
  <ul class="updates">
    <li><strong>Jun 2026</strong><span>7th International Conference on the Mathematics of Neuroscience and AI, Rome — <em>Quadratic voting reduces polarization</em></span></li>
    <li><strong>Apr 2026</strong><span>EHBEA 2026, Leiden — <em>Romantic love in French fiction (1500–1800)</em></span></li>
    <li><strong>Jun 2025</strong><span>Joined CHC Aarhus as Research Assistant</span></li>
    <li><strong>Jun 2025</strong><span>MSc Cognitive Science, Aarhus (distinction, grade A on thesis)</span></li>
  </ul>

  {recent.length > 0 && (
    <>
      <h2>Recent writing</h2>
      <ul class="recent-list">
        {recent.map((entry) => {
          const slug = entry.id.replace(/\/index$/, '');
          const date = entry.data.pubDate.toLocaleDateString('en-GB', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <li class="recent-list__item">
              <a href={`/blog/${slug}`}>
                <span class="recent-list__title">{entry.data.title}</span>
                {entry.data.description && (
                  <span class="recent-list__desc">{entry.data.description}</span>
                )}
                <span class="recent-list__date">{date}{entry.data.type === 'note' && ' · note'}</span>
              </a>
            </li>
          );
        })}
      </ul>
      <p class="recent-list__more"><a href="/blog">All writing →</a></p>
    </>
  )}

  <SiteFooter />
</Layout>
