---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Project from '../components/Project.astro';
import GithubLink from '../components/GithubLink.astro';
---

<Layout
  title="Sylvain Estebe · Computational cognitive science & cultural evolution"
  description="Computational cognitive science, cultural evolution, and computational social science. Machine learning, Bayesian modeling, LLM pipelines, agent-based simulation."
>
  <ThemeToggle />

  <div class="site-header">
    <img src="/profile.jpg" alt="Sylvain Estebe" />
    <div class="header-text">
      <h1>Sylvain Estebe</h1>
      <p class="affiliation">Research Assistant · Center for Humanities Computing · Aarhus University</p>
    </div>
  </div>

  <div class="pitch">
    <p>I study and model how environmental conditions — resources, uncertainty, volatility — shape human behavior at three scales: populations (cultural evolution, behavioral ecology), groups (collective decision-making, mechanism design), and individuals (Bayesian cognition, computational cognitive science). Tools: machine learning, LLM pipelines, agent-based simulation, hierarchical Bayesian models.</p>
  </div>

  <SocialLinks />

  <h2>Research</h2>

  <h3>Population · Cultural evolution</h3>
  <Project
    title="Romantic love in French fiction, 1500–1999"
    status="Manuscript in preparation."
  >
    LLM ensemble annotation pipeline (κ = 0.68 vs. human coders) applied to ~24,000 novels. Tests a behavioral-ecology prediction: does the rise of romantic love in fiction track changes in resource availability? With Nicolas Baumard (Institut Jean Nicod, ENS/PSL). <GithubLink href="https://github.com/SylvainEstebe/YOUR_REPO" />
  </Project>

  <h3>Group · Collective decision-making</h3>
  <Project
    title="Quadratic voting and polarization"
    status="Manuscript in preparation."
  >
    Agent-based model: 1,019 Bayesian cognitive agents comparing plurality vs. quadratic voting under environmental volatility (economic shocks, security crises). Does mechanism design reduce polarization? With Nicolas Legrand (CHC, Aarhus). <GithubLink href="https://github.com/SylvainEstebe/YOUR_REPO" />
  </Project>

  <h3>Individual · Computational cognitive science</h3>
  <Project title="A cognitive model of customer churn">
    MSc thesis. Hierarchical Bayesian model of the decision process behind customer churn — modeling how beliefs about a service evolve and tip into leaving. Used to inform data collection strategy. Industry collaboration with Norlys. Supervisor: Nicolas Legrand. <GithubLink href="https://github.com/SylvainEstebe/YOUR_REPO" />
  </Project>

  <h3>Other projects</h3>
  <Project title="Insecurity and cooperation across 13 countries">
    Decision-making modeling on public goods game data. Perceived insecurity predicts lower contributions and faster cooperation decline — individuals from high-insecurity nations show lower initial optimism and greater sensitivity to others' choices. <GithubLink href="https://github.com/SylvainEstebe/YOUR_REPO" />
  </Project>

  <Project title="Predicting the intention–action gap in childcare">
    End-to-end ML pipeline (Python) on inequality and childcare data. Full workflow: preprocessing, model fitting, evaluation, visualization. <GithubLink href="https://github.com/SylvainEstebe/YOUR_REPO" />
  </Project>

  <Project title="Cognitive distortions in embedding space">
    NLP pipeline: sentence-transformer embeddings → UMAP dimensionality reduction → HDBSCAN clustering (Bayesian-optimized) on 921 labeled thought examples. Builds a data-driven taxonomy of cognitive distortions. <GithubLink href="https://github.com/SylvainEstebe/cognitive_distortion_embeding" label="Code & dashboard" />
  </Project>

  <Project title="Cognitive effort in musical performance">
    Two internships at the University of Oslo with Laura Bishop and Bruno Laeng. Motion capture, mobile eye-tracking, and EMG to measure cognitive and physical effort in pianists. Multi-modal data analysis with wavelet methods.
  </Project>

  <h2>Industry</h2>
  <div class="about">
    <p>Data science intern at Norlys (Danish energy provider). Customer segmentation from high-dimensional data using clustering and UMAP. The thesis project above grew out of that work: segmentation surfaced <em>who</em> was leaving, the cognitive model tried to explain <em>why</em>.</p>
  </div>

  <h2>Software</h2>
  <Project title="PyHGF">
    Contributor to the open-source <a href="https://computationalpsychiatry.github.io/pyhgf/">Hierarchical Gaussian Filter library</a> — JAX-based predictive coding for computational psychiatry.
  </Project>

  <h2>Teaching & outreach</h2>
  <div class="about">
    <p>Teaching assistant, Probability Theory and Statistics for Computational Humanities (Aarhus, 2025). Mentor at the Danish Data Science Academy (2025–2026). Translator for Cognijunior — French adaptation of a neuroscience teaching kit for young audiences (2020–2022).</p>
  </div>

  <h2>Talks & updates</h2>
  <ul class="updates">
    <li><strong>Jun 2026</strong><span>neuroMONSTER, Rome — <em>Quadratic voting reduces polarization</em></span></li>
    <li><strong>Apr 2026</strong><span>EHBEA 2026, Leiden — <em>Romantic love in French fiction (1500–1800)</em></span></li>
    <li><strong>Jun 2025</strong><span>Joined CHC Aarhus as Research Assistant</span></li>
    <li><strong>Jun 2025</strong><span>MSc Cognitive Science, Aarhus (distinction, grade A on thesis)</span></li>
  </ul>

  <h2>About</h2>
  <div class="about">
    <p>One question at every scale: how do agents — minds, groups, cultures — translate environmental information into behavior? Computational cognitive science and computational social science to move between scales. Build a model, test it against data, make sure it explains something.</p>
    <p>Before academia I spent a decade as a music producer — composing for <a href="https://www.youtube.com/watch?v=POhHq6dmPWY&list=RDPOhHq6dmPWY&start_radio=1">Jok'air</a>, <a href="https://www.youtube.com/watch?v=snSiqRZDXMI&list=RDsnSiqRZDXMI&start_radio=1">Disiz</a>, and others, as well as music for ads and theater (4× gold, 1× platinum).</p>
    <p>Based in Aarhus, Denmark. Ongoing collaboration at Institut Jean Nicod (ENS/PSL, Paris).</p>
  </div>

  <h2>Contact</h2>
  <div class="about">
    <p><a href="mailto:sylvain.estebe@gmail.com">sylvain.estebe@gmail.com</a> · <a href="https://github.com/SylvainEstebe">GitHub</a> · <a href="https://orcid.org/YOUR_ORCID">ORCID</a> · <a href="https://www.linkedin.com/in/sylvain-estebe-97485a118/?locale=en">LinkedIn</a> · <a href="https://instagram.com/YOUR_INSTAGRAM">Instagram</a></p>
    <p><a href="/cv.pdf">CV (PDF)</a></p>
  </div>

  <div class="site-footer">
    Last updated April 2026 · Built with <a href="https://astro.build">Astro</a>
  </div>
</Layout>