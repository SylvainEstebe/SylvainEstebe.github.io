---
import { Image } from 'astro:assets';

interface Props {
  photo: {
    src: import('astro').ImageMetadata;
    alt: string;
    filename: string;
    caption?: string;
    location?: string;
  };
  /** Index into the flat lightbox array — drives the lightbox. */
  index: number;
}

const { photo, index } = Astro.props;
---

<button
  type="button"
  class="justified-gallery__item"
  data-index={index}
  style={`--w: ${photo.src.width}; --h: ${photo.src.height};`}
  aria-label={`Open: ${photo.alt || photo.filename}`}
>
  <Image
    src={photo.src}
    alt={photo.alt}
    widths={[400, 800, 1200]}
    sizes="(max-width: 600px) 100vw, (max-width: 1000px) 50vw, 33vw"
    loading="lazy"
  />
  {photo.caption && (
    <span class="justified-gallery__caption">
      <span>{photo.caption}</span>
      {photo.location && <span class="loc"> · {photo.location}</span>}
    </span>
  )}
</button>
